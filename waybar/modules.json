{
    "custom/arch": {
        "format": "≤░μΘ",
        "tooltip": true,
        "tooltip-format": "btw",
        "on-click": "rofi -show p -modi p:rofi-power-menu"
    },
    "custom/lyrics": {
            "return-type": "json",
            "format": "{icon} {0}",
            "hide-empty-text": true,
            "format-icons": {
                "playing": "ΎΒΜ",
                "paused": "ΎΒΝ",
                "lyric": "ΌβΟ",
                "music": "≤░ζγ",
                "no_lyric": "ΎΕ▒",
                "getting": "ΎΑβ"
            },
            "exec-if": "which waybar-lyric",
            "exec": "waybar-lyric --quiet",
            "on-click": "waybar-lyric play-pause",
            "on-click-right": "waybar-lyric next"
        },
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "ΎΒς",
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "niri/window": {
        "icon": true,
        "icon-size": 20
    },
    "pulseaudio": {
        "format": "{icon}   {volume}%",
        "format-bluetooth": "{icon}  {volume}%",
        "format-bluetooth-muted": "{icon}  Ύγσ ",
        "format-muted": "Ύγσ ",
        "format-source": " ",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        }
    },
    "network": {
        "format-wifi": "ΎΘτ   {essid} ({signalStrength}%)",
        //"format-ethernet": "{ipaddr}/{cidr} ≤░ΙΑ",
        //"tooltip-format": "{ifname} via {gwaddr} ≤░ΙΑ",
        //"format-linked": "{ifname} (No IP) ≤░ΙΑ",
        "format-ethernet": "",
        "tooltip-format": "",
        "format-linked": "",
        "format-disconnected": "Disconnected έγι",
    },
    "cpu": {
        "format": "ΎΜδ  {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "ΎΔΚ  {}%",
	"tooltip": true
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["ΎΗΗ", "ΎΗΖ"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "ΎΩπ  {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "clock": {
        "format": "{:%m/%d/%y   %I:%M:%S %p}",
        "interval": 1,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    }

}
