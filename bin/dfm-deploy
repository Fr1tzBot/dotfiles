#!/usr/bin/env bash

TRIMMED_HOME=$(realpath -s "$HOME")
DOTFILES="$TRIMMED_HOME/Documents/dotfiles"
CONFIG="$TRIMMED_HOME/.config"

has() { type -p "$1" > /dev/null; }
install_config() { has "$1" && mkdir -p "$CONFIG" && cp -ruv "$DOTFILES/$1" "$CONFIG"; }
install_home() { has "$1" && cp -ruv "${DOTFILES}/$1/"* "$TRIMMED_HOME"; }

shopt -s dotglob

PROGS_HOME=("bash" "ssh" "git" "vim")
for prog in "${PROGS_HOME[@]}"; do
    install_home "$prog"
done

PROGS_CONFIG=("foot" "kitty" "mpv" "fastfetch" "neofetch" "nvim" "rofi" "sway" "swaylock" "waybar" "niri" "dunst")
for prog in "${PROGS_CONFIG[@]}"; do
    install_config "$prog"
done

has sway && [ -f "$DOTFILES/sway/$HOSTNAME.config" ] && [ ! -e "$CONFIG/sway/osspecific.config" ] && ln -sv "$CONFIG/sway/$HOSTNAME.config" "$CONFIG/sway/osspecific.config"

cp -ruv "$DOTFILES/bin" "$TRIMMED_HOME/"

# nuke bashrc on termux to avoid double sourcing on startup
if [ -n "$TERMUX_VERSION" ] ; then
    rm -v "$TRIMMED_HOME/.bashrc"
fi
